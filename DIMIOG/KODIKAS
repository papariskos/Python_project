    "Coursera API": "https://api.coursera.org/api/catalog.v1/courses",
    "Open Library API": "https://openlibrary.org/search.json?q=computer%20science%20course",
    "University Domains API": "http://universities.hipolabs.com/search?country=Greece"
}

COURSE_KEYWORDS = [
    "bsc", "msc", "mba", "ba", "ma", "degree", "course",
    "program", "programme", "studies", "science", "business",
    "management", "computer", "psychology", "engineering",
    "law", "finance", "accounting", "marketing", "tourism",
    "πρόγραμμα", "σπουδών", "μάθημα", "πτυχίο",
    "διοίκηση", "ψυχολογία", "πληροφορική", "μηχανική",
    "νομική", "οικονομικά", "λογιστική"
]

final_list = []
csv_file_path = None


# ---------------- ΒΟΗΘΗΤΙΚΕΣ ΣΥΝΑΡΤΗΣΕΙΣ ----------------

def clean_text(text):
    text = str(text)
    text = re.sub(r"\s+", " ", text)
    return text.strip()


def classify_course(title):
    t = title.lower()

    if any(w in t for w in ["math", "statistics", "algebra", "μαθ", "στατιστικ", "λογιστικ"]):
        return "Μαθηματικής Επιστήμης"
    elif any(w in t for w in ["physics", "energy", "φυσικ", "ενέργεια"]):
        return "Φυσικής Επιστήμης"
    elif any(w in t for w in ["engineering", "computer", "informatics", "programming", "μηχαν", "πληροφορ", "προγραμματισ"]):
        return "Μηχανικής Φύσεως"
    elif any(w in t for w in ["chemistry", "biology", "χημ", "βιολογ"]):
        return "Χημικές Επιστήμες"
    elif any(w in t for w in ["psychology", "history", "philosophy", "education", "ψυχολογ", "ιστορ", "φιλοσοφ", "παιδαγωγ"]):
        return "Ανθρωπιστικές Επιστήμες"
    else:
        return "Γενικής Παιδείας"


def is_valid_course_title(title):
    title = clean_text(title)
    lower = title.lower()

    if len(title) < 10 or len(title) > 130:
        return False

    return any(keyword in lower for keyword in COURSE_KEYWORDS)


def extract_price(text):
    text = clean_text(text).lower()

    patterns = [
        r"\d{2,5}\s?€",
        r"€\s?\d{2,5}",
        r"\d{2,5}\s?euro",
        r"\d{2,5}\s?euros",
        r"\$\s?\d{2,5}",
        r"\d{2,5}\s?usd"
    ]

    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            return match.group()

    return "Δεν βρέθηκε"


def extract_cost_number(cost_text):
    match = re.search(r"\d+", str(cost_text))
    if match:
        return int(match.group())

    return 0


def extract_duration(text):
    text = clean_text(text).lower()

    patterns = [
        r"(\d+)\s?hours",
        r"(\d+)\s?hrs",
        r"(\d+)\s?hour",
        r"(\d+)\s?ώρες",
        r"(\d+)\s?ωρες"
    ]

    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            return int(match.group(1))

    return 20


def extract_difficulty(text):
    text = clean_text(text).lower()

    if any(w in text for w in ["beginner", "basic", "introductory", "intro", "αρχάρι"]):
        return "Beginner"
    elif any(w in text for w in ["intermediate", "μέτριο", "μεσαίο"]):
        return "Intermediate"
    elif any(w in text for w in ["advanced", "expert", "προχωρη"]):
        return "Advanced"
    else:
        return "Unknown"


def add_course(courses, title, provider, method, source_url, price="Δεν βρέθηκε", extra_text=""):
    title = clean_text(title)

    if not is_valid_course_title(title):
        return

    combined_text = f"{title} {price} {extra_text}"

    courses.append({
        "Title": title,
        "Provider": provider,
        "Category": classify_course(title),
        "Cost": price,
        "Cost_EUR": extract_cost_number(price),
        "Duration_Hours": extract_duration(combined_text),
        "Difficulty_Level": extract_difficulty(combined_text),
        "Extraction_Method": method,
        "URL": source_url
    })


# ---------------- WEB SCRAPING ----------------

def scrape_courses(provider, url, limit=10):
    courses = []
    seen = set()

    try:
        response = requests.get(url, headers=HEADERS, timeout=15)
        response.raise_for_status()

        soup = BeautifulSoup(response.text, "html.parser")
        tags = soup.find_all(["h1", "h2", "h3", "h4", "a", "p", "span"])

        for tag in tags:
            title = clean_text(tag.get_text(" ", strip=True))

            if title in seen:
                continue

            if is_valid_course_title(title):
                seen.add(title)

                nearby_text = clean_text(tag.parent.get_text(" ", strip=True)) if tag.parent else title
                price = extract_price(nearby_text)

                add_course(
                    courses=courses,
                    title=title,
                    provider=provider,
                    method="Web Scraping",
                    source_url=url,
                    price=price,
                    extra_text=nearby_text
                )

            if len(courses) >= limit:
                break

    except Exception as e:
        print(f"Σφάλμα στο scraping από {provider}: {e}")

    return courses


# ---------------- API FUNCTIONS ----------------

def get_coursera_api(limit=10):
    courses = []
    url = API_SOURCES["Coursera API"]

    try:
        response = requests.get(url, timeout=15)
        response.raise_for_status()
        data = response.json()

        for item in data.get("elements", []):
            title = item.get("name", "")

            add_course(
                courses=courses,
                title=title,
                provider="Coursera",
                method="API",
                source_url=url,
                price="Δεν βρέθηκε",
                extra_text=str(item)
            )

            if len(courses) >= limit:
                break

    except Exception as e:
        print(f"Σφάλμα στο Coursera API: {e}")

    return courses


def get_openlibrary_api(limit=10):
    courses = []
    url = API_SOURCES["Open Library API"]

    try:
        response = requests.get(url, timeout=15)
        response.raise_for_status()
        data = response.json()

        for item in data.get("docs", []):
            title = item.get("title", "")

            add_course(
                courses=courses,
                title=title,
                provider="Open Library",
                method="API",
                source_url=url,
                price="Δεν βρέθηκε",
                extra_text=str(item)
            )

            if len(courses) >= limit:
                break

    except Exception as e:
        print(f"Σφάλμα στο Open Library API: {e}")

    return courses


def get_universities_api(limit=10):
    courses = []
    url = API_SOURCES["University Domains API"]

    try:
        response = requests.get(url, timeout=15)
        response.raise_for_status()
        data = response.json()

        for item in data:
            university_name = item.get("name", "")
            title = f"Academic Studies - {university_name}"

            add_course(
                courses=courses,
                title=title,
                provider="University Domains API",
                method="API",
                source_url=url,
                price="Δεν βρέθηκε",
                extra_text=str(item)
            )

            if len(courses) >= limit:
                break

    except Exception as e:
        print(f"Σφάλμα στο University Domains API: {e}")

    return courses


# ---------------- CSV & ΓΡΑΦΗΜΑΤΑ ----------------

def save_to_desktop(data_list):
    desktop_path = os.path.join(os.path.expanduser("~"), "Desktop")

    now = datetime.now().strftime("%d-%m-%Y_%H-%M-%S")
    filename = f"courses_{AM_FOITITI}_{now}.csv"
    final_path = os.path.join(desktop_path, filename)

    df = pd.DataFrame(data_list)
    df.to_csv(final_path, index=False, encoding="utf-8-sig")

    return final_path


def visualize_csv_data(path):
    df = pd.read_csv(path)

    if df.empty:
        messagebox.showwarning("Προσοχή", "Το CSV είναι άδειο.")
        return

    df["Duration_Hours"] = pd.to_numeric(df["Duration_Hours"], errors="coerce").fillna(20)
    df["Cost_EUR"] = pd.to_numeric(df["Cost_EUR"], errors="coerce").fillna(0)

    top5 = df.sort_values(by="Duration_Hours", ascending=False).head(5)

    # 1. Bar Chart
    plt.figure(figsize=(10, 6))
    bars = plt.bar(top5["Title"], top5["Duration_Hours"])

    for bar in bars:
        height = bar.get_height()
        plt.text(
            bar.get_x() + bar.get_width() / 2,
            height + 0.5,
            int(height),
            ha="center",
            va="bottom"
        )

    plt.title("Bar Chart - Τα 5 Μαθήματα με τη Μεγαλύτερη Διάρκεια")
    plt.xlabel("Ονόματα Μαθημάτων")
    plt.ylabel("Διάρκεια (ώρες)")
    plt.xticks(rotation=35, ha="right")
    plt.tight_layout()
    plt.show()

    # 2. Pie Chart
    difficulty_counts = df["Difficulty_Level"].value_counts()

    plt.figure(figsize=(8, 8))
    plt.pie(
        difficulty_counts.values,
        labels=difficulty_counts.index,
        autopct="%1.1f%%",
        startangle=90
    )
    plt.title("Pie Chart - Κατανομή Επιπέδου Δυσκολίας")
    plt.tight_layout()
    plt.show()

    # 3. Line Plot
    top5_sorted = top5.sort_values(by="Duration_Hours")

    plt.figure(figsize=(10, 6))
    plt.plot(
        top5_sorted["Duration_Hours"],
        top5_sorted["Cost_EUR"],
        marker="o"
    )

    plt.title("Line Plot - Συσχέτιση Κόστους και Διάρκειας")
    plt.xlabel("Διάρκεια Μαθήματος (ώρες)")
    plt.ylabel("Κόστος Μαθήματος (€)")
    plt.grid(True, linestyle="--", alpha=0.5)
    plt.tight_layout()
    plt.show()


# ---------------- TKINTER FUNCTIONS ----------------

def clear_table():
    for row in table.get_children():
        table.delete(row)


def insert_courses_to_table(courses):
    clear_table()

    for course in courses:
        table.insert(
            "",
            tk.END,
            values=(
                course["Title"],
                course["Provider"],
                course["Category"],
                course["Cost"],
                course["Cost_EUR"],
                course["Duration_Hours"],
                course["Difficulty_Level"],
                course["Extraction_Method"],
                course["URL"]
            )
        )


def collect_data():
    global final_list, csv_file_path

    final_list = []
    csv_file_path = None

    clear_table()
    status_label.config(text="Γίνεται συλλογή δεδομένων...")
    root.update_idletasks()

    # 3 πηγές Web Scraping
    for provider, url in WEB_SOURCES.items():
        final_list.extend(scrape_courses(provider, url, limit=5))

    # 3 πηγές API
    final_list.extend(get_coursera_api(limit=5))
    final_list.extend(get_openlibrary_api(limit=5))
    final_list.extend(get_universities_api(limit=5))

    if not final_list:
        status_label.config(text="Δεν βρέθηκαν δεδομένα.")
        messagebox.showerror("Σφάλμα", "Δεν βρέθηκαν μαθήματα από Web Scraping ή API.")
        return

    if len(final_list) < 10:
        messagebox.showwarning(
            "Προσοχή",
            f"Βρέθηκαν μόνο {len(final_list)} μαθήματα. Κάποια πηγή ίσως δεν επέστρεψε δεδομένα."
        )

    insert_courses_to_table(final_list)

    status_label.config(text=f"Βρέθηκαν {len(final_list)} μαθήματα.")
    messagebox.showinfo("Ολοκληρώθηκε", f"Βρέθηκαν {len(final_list)} μαθήματα.")


def save_csv():
    global csv_file_path

    if not final_list:
        messagebox.showwarning("Προσοχή", "Πρώτα κάνε συλλογή δεδομένων.")
        return

    csv_file_path = save_to_desktop(final_list)

    status_label.config(text=f"Το CSV αποθηκεύτηκε: {csv_file_path}")
    messagebox.showinfo("Επιτυχία", f"Το CSV αποθηκεύτηκε:\n{csv_file_path}")


def show_chart():
    if not csv_file_path:
        messagebox.showwarning("Προσοχή", "Πρώτα αποθήκευσε το CSV.")
        return

    visualize_csv_data(csv_file_path)


def show_sources():
