    sources_window.title("Πηγές Δεδομένων")
    sources_window.geometry("850x450")

    text = tk.Text(sources_window, wrap="word", font=("Arial", 10))
    text.pack(expand=True, fill="both", padx=10, pady=10)

    text.insert(tk.END, "WEB SCRAPING ΠΗΓΕΣ\n\n")
    for name, url in WEB_SOURCES.items():
        text.insert(tk.END, f"{name}:\n{url}\n\n")

    text.insert(tk.END, "\nAPI ΠΗΓΕΣ\n\n")
    for name, url in API_SOURCES.items():
        text.insert(tk.END, f"{name}:\n{url}\n\n")


def search_table():
    query = search_entry.get().lower().strip()

    if not query:
        insert_courses_to_table(final_list)
        return

    filtered = []

    for course in final_list:
        combined = (
            course["Title"] +
            course["Provider"] +
            course["Category"] +
            course["Cost"] +
            course["Difficulty_Level"] +
            course["Extraction_Method"]
        ).lower()

        if query in combined:
            filtered.append(course)

    insert_courses_to_table(filtered)


def reset_search():
    search_entry.delete(0, tk.END)
    insert_courses_to_table(final_list)


