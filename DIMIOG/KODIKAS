tk.Button(button_frame, text="Συλλογή Δεδομένων", command=collect_data, width=20).grid(row=0, column=0, padx=5)
tk.Button(button_frame, text="Αποθήκευση CSV", command=save_csv, width=20).grid(row=0, column=1, padx=5)
tk.Button(button_frame, text="Εμφάνιση Γραφήματος", command=show_chart, width=20).grid(row=0, column=2, padx=5)
tk.Button(button_frame, text="Προβολή URLs", command=show_urls, width=20).grid(row=0, column=3, padx=5)

output_text = tk.Text(root, wrap="word", font=("Arial", 10))
output_text.pack(expand=True, fill="both", padx=15, pady=10)

